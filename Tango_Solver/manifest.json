{
    "manifest_version": 3,
    "name": "Tango Auto-Solver",
    "version": "1.0.0",
    "icons": {
        "16": "images/icon-16.png",
        "32": "images/icon-32.png",
        "48": "images/icon-48.png",
        "128": "images/icon-128.png"
    },
    "description": "Automatically parses and solves the LinkedIn Tango game (https://www.linkedin.com/games/tango/).",
    "action": {
        "default_popup": "popup.html",
        "default_title": "Solve Tango"
    },
    "permissions": ["scripting"],
    "host_permissions": ["*://*.linkedin.com/*"]
}
