{
    "manifest_version": 3,
    "name": "Zip Puzzle Solver",
    "version": "1.0.0",
    "description": "Automatically parses and solves the LinkedIn game Zip.",
    "action": {
        "default_popup": "popup.html",
        "default_title": "Solve Zip"
    },
    "permissions": ["scripting"],
    "host_permissions": ["*://*.linkedin.com/*"]
}
